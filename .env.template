# Ivan Prints — Environment Variable Template
# Copy to .env.local and fill in values. Never commit .env.local
#
# Local Supabase values: run `npx supabase status` after `npx supabase start`
# Cloud values: Supabase dashboard → Project Settings → API

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# WARNING: SERVER-SIDE ONLY. Never use in client components or NEXT_PUBLIC_ vars.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ─── Application ──────────────────────────────────────────────────────────────
# Local: http://localhost:3000  |  Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Sentry Error Tracking ────────────────────────────────────────────────────
# Get from: Sentry → Project Settings → Client Keys
# Leave blank in local dev to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Sentry org/project slugs (from your Sentry URL: sentry.io/organizations/<org>/projects/<project>)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# For source map uploads in CI (Settings → Auth Tokens → Create token with project:releases scope)
SENTRY_AUTH_TOKEN=

# ─── Cron / Background Jobs ───────────────────────────────────────────────────
# Generate a secure random secret: openssl rand -hex 32
# Used to authenticate calls to /api/cron/** endpoints
CRON_SECRET=

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_REDIRECT_PATH=/auth/callback

# ─── Development Flags (local only, never set in production) ──────────────────
# These are read by the app but should always be false/unset in production
NEXT_PUBLIC_SKIP_PROFILE_CHECK=false
